---
import { business } from '@/config/business';

const nav = [
  { href: '/services/', label: 'Services' },
  { href: '/instant-quote/', label: 'Instant Quote' },
  { href: '/service-areas/', label: 'Service Areas' },
  { href: '/projects/', label: 'Projects' },
  { href: '/financing/', label: 'Financing' },
  { href: '/blog/', label: 'Guides' },
  { href: '/about/', label: 'About' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-navy-950/95 text-white shadow-[0_8px_32px_-16px_rgb(11_26_43/0.8)] backdrop-blur">
  <div class="hidden border-b border-white/10 bg-navy-900/60 md:block">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-1.5 text-xs text-white/60 sm:px-6">
      <p class="flex items-center gap-4">
        <span class="font-semibold tracking-wide text-white/75">{business.license}</span>
        <span class="hidden lg:inline">Licensed &amp; fully insured</span>
        <span class="hidden xl:inline">Serving {business.areaServed}</span>
      </p>
      <p class="flex items-center gap-4">
        <span>{business.hours}</span>
        <span class="text-gold-300/90">Free estimates · Same-day response</span>
      </p>
    </div>
  </div>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2.5" aria-label={`${business.name} home`}>
      <img src="/media/logo.png" alt="" width="48" height="48" class="h-12 w-12 object-contain" aria-hidden="true" />
      <span class="font-display leading-none">
        <span class="block text-lg font-extrabold tracking-wide">PARAGON</span>
        <span class="block text-[0.65rem] font-semibold tracking-[0.28em] text-gold-300">EXTERIORS LLC</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="group relative py-1 font-display text-sm font-semibold text-white/85 transition hover:text-white"
          >
            {item.label}
            <span
              class="absolute inset-x-0 -bottom-0.5 h-0.5 origin-left scale-x-0 rounded-full bg-gold-400 transition-transform duration-200 group-hover:scale-x-100"
              aria-hidden="true"
            />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href={business.phoneHref} class="hidden items-center gap-2 font-display font-bold text-gold-300 sm:flex">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24 11.36 11.36 0 0 0 3.57.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.36 11.36 0 0 0 .57 3.57 1 1 0 0 1-.25 1.02l-2.2 2.2Z" />
        </svg>
        {business.phone}
      </a>
      <a href="/contact/" class="btn-gold !px-4 !py-2 text-sm">Free Estimate</a>
      <a
        href="/admin"
        class="hidden items-center gap-1.5 rounded border border-white/25 px-3 py-2 font-display text-sm font-semibold text-white/85 transition hover:border-gold-400 hover:text-white md:flex"
      >
        Admin Portal
      </a>
      <button
        id="nav-toggle"
        class="rounded p-2 text-white lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-white/10 lg:hidden">
    <nav class="mx-auto max-w-7xl space-y-1 px-4 py-4" aria-label="Mobile">
      {
        nav.map((item) => (
          <a href={item.href} class="block rounded px-3 py-2.5 font-display font-semibold text-white/90 hover:bg-white/5">
            {item.label}
          </a>
        ))
      }
      <a href={business.phoneHref} class="block rounded px-3 py-2.5 font-display font-bold text-gold-300">
        Call {business.phone}
      </a>
      <a
        href="/admin"
        class="block rounded px-3 py-2.5 font-display font-semibold text-white/90 hover:bg-white/5"
      >
        Admin Portal
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
