---
import { getCollection } from 'astro:content';

interface Props {
  heading?: string;
  /** Link pattern: '/service-areas/{town}/' (default) or '/{service}/{town}/'. */
  service?: string;
  compact?: boolean;
}
const { heading = 'Proudly serving the Jersey Shore', service, compact = false } = Astro.props;
const towns = (await getCollection('towns')).sort((a, b) => a.data.town.localeCompare(b.data.town));
const counties = ['Ocean', 'Monmouth', 'Middlesex'] as const;
const href = (townId: string) => (service ? `/${service}/${townId}/` : `/service-areas/${townId}/`);
---

<section class:list={['mx-auto max-w-7xl px-4 sm:px-6', compact ? 'py-10' : 'py-16']}>
  <h2 class="h-display text-3xl text-navy-950">{heading}</h2>
  <p class="mt-2 max-w-2xl text-navy-900/70">
    Local crews, local knowledge — from barrier-island salt air to inland wooded lots.
  </p>
  <div class="mt-8 grid gap-8 md:grid-cols-3">
    {
      counties.map((county) => {
        const list = towns.filter((t) => t.data.county === county);
        return (
          list.length > 0 && (
            <div>
              <h3 class="font-display text-lg font-extrabold text-navy-900">{county} County</h3>
              <ul class="mt-3 grid grid-cols-2 gap-x-3 gap-y-2 text-sm">
                {list.map((t) => (
                  <li>
                    <a href={href(t.id)} class="text-navy-800 hover:text-gold-600 hover:underline">
                      {t.data.town}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        );
      })
    }
  </div>
</section>
