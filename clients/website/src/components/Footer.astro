---
import { getCollection } from 'astro:content';
import { business } from '@/config/business';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const towns = (await getCollection('towns')).sort((a, b) => a.data.town.localeCompare(b.data.town));
const year = new Date().getFullYear();
---

<footer class="bg-navy-950 text-white/80">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="font-display text-xl font-extrabold text-white">PARAGON EXTERIORS LLC</p>
      <p class="mt-2 text-sm italic text-gold-300">{business.tagline}</p>
      <p class="mt-4 text-sm leading-relaxed">
        Residential &amp; commercial roofing, siding, windows, doors, decks and gutters across {business.areaServed}.
      </p>
      <p class="mt-4 font-display text-sm font-bold tracking-wide text-white">{business.license}</p>
      <p class="mt-1 text-sm">Licensed &amp; fully insured · Financing available</p>
      <div class="mt-4 flex gap-4">
        <a href={business.social.instagram} rel="noopener" target="_blank" aria-label="Instagram" class="hover:text-gold-300">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 3.25.15 4.73 1.66 4.88 4.88.06 1.25.07 1.64.07 4.85s0 3.6-.07 4.85c-.15 3.22-1.66 4.73-4.88 4.88-1.25.06-1.64.07-4.85.07s-3.6 0-4.85-.07c-3.22-.15-4.73-1.66-4.88-4.88C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85C2.42 3.93 3.93 2.42 7.15 2.27 8.4 2.2 8.8 2.2 12 2.2Zm0 3.68a6.12 6.12 0 1 0 0 12.24 6.12 6.12 0 0 0 0-12.24Zm0 10.1a3.98 3.98 0 1 1 0-7.96 3.98 3.98 0 0 1 0 7.96Zm6.36-11.85a1.43 1.43 0 1 0 0 2.86 1.43 1.43 0 0 0 0-2.86Z"/></svg>
        </a>
        <a href={business.social.facebook} rel="noopener" target="_blank" aria-label="Facebook" class="hover:text-gold-300">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.5-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46H15.2c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12Z"/></svg>
        </a>
      </div>
    </div>

    <nav aria-label="Services">
      <p class="font-display font-bold text-white">Services</p>
      <ul class="mt-3 space-y-2 text-sm">
        {
          services.map((s) => (
            <li>
              <a href={`/${s.id}/`} class="hover:text-gold-300">
                {s.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="Service areas">
      <p class="font-display font-bold text-white">Serving the Jersey Shore</p>
      <ul class="mt-3 grid grid-cols-2 gap-x-3 gap-y-2 text-sm">
        {
          towns.slice(0, 18).map((t) => (
            <li>
              <a href={`/service-areas/${t.id}/`} class="hover:text-gold-300">
                {t.data.town}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="/service-areas/" class="mt-3 inline-block text-sm font-semibold text-gold-300 hover:underline">
        All service areas →
      </a>
    </nav>

    <div>
      <p class="font-display font-bold text-white">Talk to us</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href={business.phoneHref} class="font-display text-lg font-extrabold text-gold-300">{business.phone}</a>
        </li>
        <li><a href={business.emailHref} class="hover:text-gold-300">{business.email}</a></li>
        <li>{business.hours}</li>
        <li><a href="/how-we-get-found/" class="hover:text-gold-300">How we get found online</a></li>
        <li class="pt-2">
          <a href="/contact/" class="btn-gold !px-4 !py-2 text-sm">Get a Free Estimate</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-5 text-xs text-white/50 sm:px-6">
      <p>© {year} {business.legalName}. All rights reserved. {business.license}.</p>
      <p class="flex gap-4">
        <a href="/privacy-policy/" class="hover:text-white">Privacy Policy</a>
        <a href="/accessibility-statement/" class="hover:text-white">Accessibility</a>
        <a href="/sitemap-index.xml" class="hover:text-white">Sitemap</a>
      </p>
    </div>
  </div>
</footer>
