---
import Img from '@/components/Img.astro';

/**
 * Before/After comparison slider — drag the handle (or use arrow keys) to
 * reveal the "before" image over the "after" image.
 *
 * Accessibility + CWV notes:
 *  - the control is a real `<input type="range">` stretched over the media,
 *    so it is keyboard- and screen-reader operable for free;
 *  - the aspect ratio is reserved up front (no CLS);
 *  - purely CSS-variable driven — no layout work on drag, and nothing moves
 *    on its own, so `prefers-reduced-motion` needs no special casing.
 *
 * Swap the demo images for a real tear-off pair per service/town as
 * photography comes in — pass `before`/`after` `/media/...` paths.
 */
interface Props {
  before: string;
  after: string;
  beforeAlt: string;
  afterAlt: string;
  heading?: string;
  subheading?: string;
  class?: string;
}

const {
  before,
  after,
  beforeAlt,
  afterAlt,
  heading,
  subheading,
  class: className,
} = Astro.props;
---

{
  heading && (
    <div class="mx-auto max-w-7xl px-4 pt-16 sm:px-6">
      <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-500">See the difference</p>
      <h2 class="h-display mt-3 text-3xl text-navy-950 sm:text-4xl">{heading}</h2>
      {subheading && <p class="mt-3 max-w-2xl text-navy-900/70">{subheading}</p>}
    </div>
  )
}

<div class:list={['mx-auto max-w-7xl px-4 py-10 sm:px-6', className]}>
  <div
    class="ba-slider group relative aspect-[16/9] w-full select-none overflow-hidden rounded-2xl shadow-xl"
    data-ba-slider
    style="--ba-pos: 50%"
  >
    <Img
      src={after}
      alt={afterAlt}
      widths={[768, 1280, 1920]}
      sizes="(max-width: 1280px) 100vw, 1280px"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0" style="clip-path: inset(0 calc(100% - var(--ba-pos)) 0 0)">
      <Img
        src={before}
        alt={beforeAlt}
        widths={[768, 1280, 1920]}
        sizes="(max-width: 1280px) 100vw, 1280px"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </div>

    <span class="pointer-events-none absolute left-4 top-4 rounded bg-navy-950/80 px-2.5 py-1 font-display text-xs font-bold uppercase tracking-wider text-white">
      Before
    </span>
    <span class="pointer-events-none absolute right-4 top-4 rounded bg-gold-400/90 px-2.5 py-1 font-display text-xs font-bold uppercase tracking-wider text-navy-950">
      After
    </span>

    <!-- Divider + handle, driven by --ba-pos -->
    <div
      class="pointer-events-none absolute inset-y-0 w-0.5 -translate-x-1/2 bg-white shadow-[0_0_8px_rgba(0,0,0,0.5)]"
      style="left: var(--ba-pos)"
      aria-hidden="true"
    >
      <span class="absolute left-1/2 top-1/2 grid h-11 w-11 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-white text-navy-950 shadow-lg">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="m9 6-6 6 6 6M15 6l6 6-6 6" />
        </svg>
      </span>
    </div>

    <input
      type="range"
      min="0"
      max="100"
      value="50"
      step="1"
      aria-label="Drag to compare before and after"
      class="absolute inset-0 h-full w-full cursor-ew-resize opacity-0"
    />
  </div>
</div>

<script>
  for (const slider of document.querySelectorAll<HTMLElement>('[data-ba-slider]')) {
    const range = slider.querySelector<HTMLInputElement>('input[type="range"]');
    range?.addEventListener('input', () => {
      slider.style.setProperty('--ba-pos', `${range.value}%`);
    });
  }
</script>
