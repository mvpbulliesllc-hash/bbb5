---
import Img from '@/components/Img.astro';

/**
 * Interactive before/after comparison slider. The whole surface is an
 * invisible <input type=range>, so dragging, tapping, touch, and arrow-key
 * control all come free with native semantics (no JS beyond wiring the CSS
 * var). The after image sits underneath; the before image is clipped from
 * the right via clip-path driven by --pos.
 */
interface Props {
  before: string;
  after: string;
  alt: string;
  /** aspect-ratio utility class, e.g. "aspect-[4/3]" */
  aspect?: string;
  caption?: string;
}
const { before, after, alt, aspect = 'aspect-[4/3]', caption } = Astro.props;
const id = `ba-${Math.random().toString(36).slice(2, 8)}`;
---

<figure class="group/ba select-none">
  <div
    class:list={[
      'relative isolate overflow-hidden rounded-2xl bg-navy-950 shadow-lift ring-1 ring-navy-950/10',
      aspect,
    ]}
    data-ba-root
    style="--pos: 50%"
  >
    <Img
      src={after}
      alt={`${alt} — after`}
      widths={[640, 960, 1400]}
      sizes="(max-width: 1024px) 100vw, 50vw"
      class="absolute inset-0 h-full w-full object-cover"
      draggable="false"
    />
    <div class="absolute inset-0" style="clip-path: inset(0 calc(100% - var(--pos)) 0 0)">
      <Img
        src={before}
        alt={`${alt} — before`}
        widths={[640, 960, 1400]}
        sizes="(max-width: 1024px) 100vw, 50vw"
        class="absolute inset-0 h-full w-full object-cover"
        draggable="false"
      />
    </div>

    <!-- Divider + grip -->
    <div class="pointer-events-none absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 bg-white shadow-[0_0_12px_rgb(0_0_0/0.45)]" style="left: var(--pos)">
      <span class="absolute left-1/2 top-1/2 flex h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-navy-950 shadow-lift ring-1 ring-navy-950/10 backdrop-blur transition-transform duration-200 group-hover/ba:scale-110">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 6-5 6 5 6M15 6l5 6-5 6" />
        </svg>
      </span>
    </div>

    <!-- Labels -->
    <span class="pointer-events-none absolute left-4 top-4 z-10 rounded-full bg-navy-950/70 px-3 py-1 font-display text-xs font-bold uppercase tracking-wider text-white backdrop-blur-sm">
      Before
    </span>
    <span class="pointer-events-none absolute right-4 top-4 z-10 rounded-full bg-gold-500/90 px-3 py-1 font-display text-xs font-bold uppercase tracking-wider text-navy-950 backdrop-blur-sm">
      After
    </span>

    <input
      type="range"
      min="0"
      max="100"
      value="50"
      step="0.1"
      aria-label={`Compare before and after: ${alt}`}
      id={id}
      data-ba-range
      class="absolute inset-0 z-20 h-full w-full cursor-ew-resize appearance-none bg-transparent opacity-0 outline-none"
    />
  </div>
  {caption && <figcaption class="mt-3 text-sm text-navy-900/65">{caption}</figcaption>}
</figure>

<script>
  document.querySelectorAll<HTMLInputElement>('[data-ba-range]').forEach((range) => {
    const root = range.closest<HTMLElement>('[data-ba-root]');
    if (!root) return;
    const update = () => root.style.setProperty('--pos', `${range.valueAsNumber}%`);
    range.addEventListener('input', update);
    update();
  });
</script>
