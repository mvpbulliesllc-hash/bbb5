---
import { business, integrations } from '@/config/business';

/**
 * Full-width hook-video block below the hero — a purpose-built 10s cinematic
 * hook ("30 ROOFS. / 30 DAYS. / ZERO SHORTCUTS. / YOUR ROOF. DONE IN A DAY.")
 * with text beats + logo end card baked in and a cinematic audio bed.
 *
 * Source: /media/hero-hook.mp4 (16:9, has audio) — generated via Higgsfield
 * (Kling 3.0) and finished in the asset pipeline. Poster is hero-static.jpg so
 * there's no blank flash before load. The real Instagram reel stays lower on
 * the page in the InstagramBand (its native vertical format).
 *
 * Rendering: <mux-player> when PUBLIC_MUX_PLAYBACK_ID is set (upload the same
 * mp4 to Mux for adaptive streaming); otherwise the local file. Autoplays
 * muted + looping per browser policy, with a prominent unmute button and
 * native controls so viewers can hear it.
 */
const muxId = integrations.muxPlaybackId;
---

<section class="bg-navy-950">
  <div class="relative w-full">
    <div class="relative aspect-video w-full overflow-hidden bg-black">
      {
        muxId ? (
          <mux-player
            playback-id={muxId}
            autoplay="muted"
            loop
            muted
            playsinline
            poster="/media/hero-static.jpg"
            style="width:100%;height:100%;--media-object-fit:cover;--controls:none;"
            data-feature-video
          />
        ) : (
          <video
            id="feature-video"
            class="h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/media/hero-static.jpg"
            data-feature-video
          >
            <source src="/media/hero-hook.mp4" type="video/mp4" />
          </video>
        )
      }

      <!-- Unmute affordance — this hook video has a cinematic audio bed. -->
      <button
        id="feature-unmute"
        type="button"
        class="absolute bottom-4 right-4 z-10 inline-flex items-center gap-2 rounded-full bg-gold-500/95 px-4 py-2 font-display text-sm font-bold text-navy-950 shadow-lift transition hover:bg-gold-400"
        aria-label="Unmute video"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3 10v4h4l5 5V5L7 10H3Zm13.5 2a4.5 4.5 0 0 0-2.5-4.03v8.06A4.5 4.5 0 0 0 16.5 12Z" />
          <path d="m19 4-1.4 1.4a9 9 0 0 1 0 13.2L19 20a11 11 0 0 0 0-16Z" />
        </svg>
        Tap for sound
      </button>
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 pb-14 pt-6 text-center sm:px-6">
    <a href="/contact/" class="btn-gold" data-cta="feature-video-estimate">Get your free estimate</a>
    <span class="mx-3 text-white/40">or</span>
    <a href={business.phoneHref} class="font-display font-bold text-gold-300">{business.phone}</a>
  </div>
</section>

{muxId && <script>import '@mux/mux-player';</script>}

<script>
  const vid = document.querySelector<HTMLVideoElement>('#feature-video');
  const muxEl = document.querySelector('mux-player[data-feature-video]') as
    | (HTMLElement & { muted?: boolean; play?: () => void })
    | null;
  const btn = document.getElementById('feature-unmute');

  const enableSound = () => {
    if (vid) {
      vid.muted = false;
      vid.volume = 1;
      void vid.play().catch(() => {});
    }
    if (muxEl) {
      muxEl.muted = false;
      muxEl.play?.();
    }
    btn?.classList.add('hidden');
    window.gtag?.('event', 'feature_video_unmute');
  };

  btn?.addEventListener('click', enableSound);
  vid?.addEventListener('volumechange', () => {
    if (vid && !vid.muted) btn?.classList.add('hidden');
  });
</script>
