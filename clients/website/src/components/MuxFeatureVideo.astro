---
import { business, integrations } from '@/config/business';

/**
 * Full-width video band directly below the hero — the "30 roofs in 30 days"
 * reel.
 *
 * Audio note: the downloadable copy of the Instagram reel is video-only
 * (Instagram served the stream without its audio track), so the LOCAL
 * fallback has no sound to play. Real audio comes through Mux — upload the
 * original reel to Mux and set PUBLIC_MUX_PLAYBACK_ID, and this band plays it
 * with full controls (including volume). Until then the local file plays as a
 * muted cinematic loop, and we link viewers to the reel on Instagram to hear
 * the sound.
 *
 * Rendering, best-available first:
 *  1. PUBLIC_MUX_PLAYBACK_ID set → <mux-player> with controls (audio playable).
 *  2. Local fallback (public/media/hero-reel.mp4) → muted autoplay loop.
 */
const muxId = integrations.muxPlaybackId;
const reelUrl = 'https://www.instagram.com/p/DYDPAwvvVZx/';
---

<section class="bg-navy-950">
  <div class="mx-auto max-w-3xl px-4 pt-14 text-center sm:px-6">
    <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-300">Watch it happen</p>
    <h2 class="h-display mt-3 text-3xl text-white sm:text-4xl">30 roofs. 30 days.</h2>
    <p class="mt-3 text-white/70">Real crews, real drone footage — this is how we work.</p>
  </div>

  <div class="relative mt-8 w-full">
    <div class="relative aspect-video w-full overflow-hidden bg-black sm:aspect-[21/9]">
      {
        muxId ? (
          <mux-player
            playback-id={muxId}
            autoplay="muted"
            loop
            muted
            playsinline
            poster="/media/hero-poster.jpg"
            style="width:100%;height:100%;--media-object-fit:cover;"
          />
        ) : (
          <video
            class="h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/media/hero-poster.jpg"
          >
            <source src="/media/hero-reel.mp4" type="video/mp4" />
          </video>
        )
      }

      {
        /* Local copy is silent → send viewers to the reel on Instagram for sound.
           With Mux configured, the player's own controls handle audio. */
        !muxId && (
          <a
            href={reelUrl}
            target="_blank"
            rel="noopener"
            class="absolute bottom-4 right-4 z-10 inline-flex items-center gap-2 rounded-full bg-gold-500/95 px-4 py-2 font-display text-sm font-bold text-navy-950 shadow-lift transition hover:bg-gold-400"
            data-cta="feature-video-instagram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 10v4h4l5 5V5L7 10H3Zm13.5 2a4.5 4.5 0 0 0-2.5-4.03v8.06A4.5 4.5 0 0 0 16.5 12Z" />
              <path d="m19 4-1.4 1.4a9 9 0 0 1 0 13.2L19 20a11 11 0 0 0 0-16Z" />
            </svg>
            Watch with sound on Instagram
          </a>
        )
      }
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 pb-14 pt-6 text-center sm:px-6">
    <a href="/contact/" class="btn-gold" data-cta="feature-video-estimate">Get your free estimate</a>
    <span class="mx-3 text-white/40">or</span>
    <a href={business.phoneHref} class="font-display font-bold text-gold-300">{business.phone}</a>
  </div>
</section>

{muxId && <script>import '@mux/mux-player';</script>}
