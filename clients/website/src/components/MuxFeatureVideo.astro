---
import { business, integrations } from '@/config/business';

/**
 * Full-width hook-video block below the hero — a purpose-built 10s cinematic
 * hook ("30 ROOFS. / 30 DAYS. / ZERO SHORTCUTS. / YOUR ROOF. DONE IN A DAY.")
 * with text beats + logo end card baked in and a spoken voiceover reading the
 * hook, loudness-normalized.
 *
 * Source: /media/hero-hook.mp4 (16:9, AAC voiceover track). A `?v=` query on
 * the src cache-busts the immutable /media cache whenever the clip is rebuilt
 * — without it, browsers keep serving the previously-cached (older) file.
 * Poster is hero-static.jpg so there's no blank flash.
 *
 * SOUND: browsers forbid autoplay WITH sound, so the clip autostarts muted and
 * loops. The center button is an explicit, reliable toggle; as a fallback the
 * first interaction anywhere else on the page unmutes once. Uses <mux-player>
 * when PUBLIC_MUX_PLAYBACK_ID is set, else the local file.
 */
const muxId = integrations.muxPlaybackId;
---

<section class="bg-navy-950">
  <div class="relative w-full">
    <div class="group relative aspect-video w-full overflow-hidden bg-black">
      {
        muxId ? (
          <mux-player
            playback-id={muxId}
            autoplay="muted"
            loop
            muted
            playsinline
            poster="/media/hero-static.jpg"
            style="width:100%;height:100%;--media-object-fit:cover;--controls:none;"
            data-feature-video
          />
        ) : (
          <video
            id="feature-video"
            class="h-full w-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/media/hero-static.jpg"
            data-feature-video
          >
            <source src="/media/hero-hook.mp4?v=2" type="video/mp4" />
          </video>
        )
      }

      <!-- Unmissable sound toggle overlay -->
      <button
        id="feature-sound"
        type="button"
        class="absolute inset-0 z-10 flex items-end justify-center pb-6 sm:pb-10"
        aria-label="Turn sound on"
      >
        <span
          id="feature-sound-pill"
          class="pointer-events-none inline-flex items-center gap-2 rounded-full bg-gold-500/95 px-5 py-2.5 font-display text-sm font-bold text-navy-950 shadow-lift ring-2 ring-white/30 transition group-hover:scale-105"
        >
          <svg id="feature-sound-off" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3 10v4h4l5 5V5L7 10H3Z" />
            <path d="m16.5 8.5 5 5m0-5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
          </svg>
          <svg id="feature-sound-on" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3 10v4h4l5 5V5L7 10H3Zm13.5 2a4.5 4.5 0 0 0-2.5-4.03v8.06A4.5 4.5 0 0 0 16.5 12Z" />
            <path d="m19 4-1.4 1.4a9 9 0 0 1 0 13.2L19 20a11 11 0 0 0 0-16Z" />
          </svg>
          <span id="feature-sound-label">Tap for sound</span>
        </span>
      </button>
    </div>
  </div>

  <div class="mx-auto max-w-3xl px-4 pb-14 pt-6 text-center sm:px-6">
    <a href="/contact/" class="btn-gold" data-cta="feature-video-estimate">Get your free estimate</a>
    <span class="mx-3 text-white/40">or</span>
    <a href={business.phoneHref} class="font-display font-bold text-gold-300">{business.phone}</a>
  </div>
</section>

{muxId && <script>import '@mux/mux-player';</script>}

<!--
  is:inline is deliberate. This logic must ship verbatim on the page. When it
  was a bundled <script>, Astro hoisted it into the same chunk as the sibling
  `import '@mux/mux-player'` script and the logic was dropped from the build
  entirely — the "Tap for sound" button had no handler, so tapping did nothing.
  Inline + plain JS keeps it independent and guaranteed-present.
-->
<script is:inline>
  (function () {
    var vid = document.getElementById('feature-video');
    var muxEl = document.querySelector('mux-player[data-feature-video]');
    var btn = document.getElementById('feature-sound');
    var pill = document.getElementById('feature-sound-pill');
    var iconOff = document.getElementById('feature-sound-off');
    var iconOn = document.getElementById('feature-sound-on');
    var label = document.getElementById('feature-sound-label');
    var soundOn = false;
    var decided = false; // latched once the viewer explicitly toggles via the button
    var EVENTS = ['pointerdown', 'touchstart', 'keydown', 'wheel'];

    function render() {
      if (iconOff) iconOff.classList.toggle('hidden', soundOn);
      if (iconOn) iconOn.classList.toggle('hidden', !soundOn);
      if (label) label.textContent = soundOn ? 'Sound on' : 'Tap for sound';
      if (pill) {
        pill.classList.toggle('bg-gold-500/95', !soundOn);
        pill.classList.toggle('bg-navy-900/80', soundOn);
        pill.classList.toggle('text-white', soundOn);
      }
    }

    function apply(on) {
      soundOn = on;
      if (vid) {
        vid.muted = !on;
        vid.volume = 1;
        if (on) { var p = vid.play(); if (p && p.catch) p.catch(function () {}); }
      }
      if (muxEl) {
        muxEl.muted = !on;
        if (on && muxEl.play) muxEl.play();
      }
      render();
    }

    function stopAuto() {
      EVENTS.forEach(function (ev) { window.removeEventListener(ev, autoUnmute); });
    }

    // First interaction ELSEWHERE on the page unmutes once (autoplay-policy
    // safe: it runs inside a real user gesture). Taps on the button are handled
    // by the explicit toggle below; skip them here so the two don't fight.
    function autoUnmute(e) {
      if (decided) { stopAuto(); return; }
      if (btn && e.target && btn.contains(e.target)) return;
      apply(true);
      if (window.gtag) window.gtag('event', 'feature_video_unmute', { trigger: 'first_interaction' });
      stopAuto();
    }

    // The overlay button is the primary, reliable control: an explicit toggle.
    if (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        decided = true;
        apply(!soundOn);
        stopAuto();
        if (window.gtag) window.gtag('event', soundOn ? 'feature_video_unmute' : 'feature_video_mute');
      });
    }

    EVENTS.forEach(function (ev) { window.addEventListener(ev, autoUnmute, { passive: true }); });
  })();
</script>
