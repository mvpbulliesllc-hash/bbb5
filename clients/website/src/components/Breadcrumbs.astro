---
interface Props {
  items: ReadonlyArray<{ name: string; url: string }>;
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mx-auto max-w-7xl px-4 pt-6 text-sm sm:px-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-navy-900/60">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span aria-hidden="true">/</span>}
          {i === items.length - 1 ? (
            <span aria-current="page" class="font-semibold text-navy-900">
              {item.name}
            </span>
          ) : (
            <a href={item.url} class="hover:text-navy-900 hover:underline">
              {item.name}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
