---
import { reviews, aggregateRating } from '@/config/reviews';

/**
 * Testimonial cards v2 — driven by src/config/reviews.ts (the same source
 * as the aggregateRating / Review JSON-LD, so on-page proof and markup
 * never drift apart). Cards show reviewer name + service + town when known.
 */
---

<section class="bg-navy-950 py-16" aria-label="Customer reviews">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-300">Homeowners on Paragon</p>
        <h2 class="h-display mt-3 text-3xl text-white sm:text-4xl">Our neighbors say it best</h2>
      </div>
      <p class="text-sm text-white/70">
        <span class="font-display text-lg font-extrabold text-gold-300">{aggregateRating.ratingValue.toFixed(1)} / 5</span>
        &nbsp;across {aggregateRating.reviewCount} reviews
      </p>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        reviews.map((r) => (
          <figure class="flex flex-col justify-between rounded-2xl bg-white/5 p-6 ring-1 ring-white/10">
            <div>
              <div class="flex gap-1 text-gold-400" aria-label={`${r.rating} out of 5 stars`}>
                {Array.from({ length: r.rating }).map(() => (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-4 leading-relaxed text-white/85">“{r.quote}”</blockquote>
            </div>
            <figcaption class="mt-5 border-t border-white/10 pt-4">
              <p class="font-display font-bold text-white">{r.author}</p>
              <p class="text-sm text-white/60">
                {r.service}
                {r.town && ` · ${r.town}`}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
