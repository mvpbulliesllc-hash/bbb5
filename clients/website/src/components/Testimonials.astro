---
/**
 * PLACEHOLDERS — owner must fill before merge (see PR description). Never
 * fabricate a rating or review count. Rendered literally so the tokens are
 * impossible to miss on the page.
 *   GOOGLE_RATING       — average star rating, e.g. "4.9"
 *   GOOGLE_REVIEW_COUNT — number of Google reviews, e.g. "60"
 *   GOOGLE_REVIEWS_URL  — link to the Google reviews profile
 */
const GOOGLE_RATING = '{{GOOGLE_RATING}}';
const GOOGLE_REVIEW_COUNT = '{{GOOGLE_REVIEW_COUNT}}';
const GOOGLE_REVIEWS_URL = '{{GOOGLE_REVIEWS_URL}}';

/** Real reviews carried over from the previous site. */
const reviews = [
  {
    quote:
      'From the initial meeting with Joe and Frank, all the way through the completion of our new roof and chimney cap, the process was seamless. Their team is professional, showed up when they said, delivered on all deadlines and the clean up was impeccable. The workmanship and warranty far exceeded anything we were offered by the other roofing companies.',
    name: 'Rob & Linda',
    detail: 'Roof replacement',
  },
  {
    quote:
      'We are extremely satisfied with the work done by Paragon Exteriors. Their team was professional, efficient, and the results exceeded our expectations.',
    name: 'Dan Marone',
    detail: 'Exterior renovation',
  },
  {
    quote:
      'Professionalism, reliability, and excellence define the people at Paragon Exteriors. They transformed our roof with skill and precision.',
    name: "Lisa O'Neill",
    detail: 'Roof replacement',
  },
];
---

<section class="section-dark py-20 lg:py-24" aria-label="Customer reviews">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <p class="eyebrow text-gold-300">Homeowners on Paragon</p>
    <h2 class="h-display mt-3 text-3xl text-white sm:text-4xl">Our neighbors say it best</h2>

    <a
      href={GOOGLE_REVIEWS_URL}
      rel="noopener"
      target="_blank"
      class="mt-6 inline-flex flex-wrap items-center gap-x-3 gap-y-1 rounded-full bg-white/[0.06] px-4 py-2 ring-1 ring-white/10 transition hover:ring-white/25"
    >
      <span class="flex gap-0.5 text-gold-400" aria-hidden="true">
        {
          Array.from({ length: 5 }).map(() => (
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
            </svg>
          ))
        }
      </span>
      <span class="font-display text-sm font-bold text-white">
        {GOOGLE_RATING} stars · {GOOGLE_REVIEW_COUNT}+ Google reviews
      </span>
      <span class="text-xs font-semibold text-gold-300">Read them on Google →</span>
    </a>

    <div class="mt-10 grid gap-6 lg:grid-cols-3" data-reveal-group>
      {
        reviews.map((r) => (
          <figure
            class="relative flex flex-col justify-between rounded-2xl bg-gradient-to-b from-white/[0.09] to-white/[0.04] p-7 ring-1 ring-white/10 backdrop-blur-sm transition duration-300 hover:ring-white/20"
            data-spotlight
            style="--spotlight-color: rgb(223 151 34 / 0.1)"
          >
            <span class="pointer-events-none absolute -top-1 right-6 font-display text-[5rem] font-extrabold leading-none text-gold-400/15" aria-hidden="true">
              “
            </span>
            <div>
              <div class="flex gap-1 text-gold-400" aria-label="5 out of 5 stars">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-4 leading-relaxed text-white/85">“{r.quote}”</blockquote>
            </div>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-white/10 pt-5">
              <span class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-gold-400/15 font-display text-sm font-extrabold text-gold-300" aria-hidden="true">
                {r.name.charAt(0)}
              </span>
              <span class="min-w-0">
                <p class="font-display font-bold text-white">{r.name}</p>
                <p class="text-sm text-white/60">{r.detail}</p>
              </span>
              <span class="ml-auto inline-flex flex-none items-center gap-1.5 rounded-full bg-white/[0.06] px-2.5 py-1 text-xs font-semibold text-white/70 ring-1 ring-white/10">
                <svg width="13" height="13" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5a5.6 5.6 0 0 1-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8Z" />
                  <path fill="#34A853" d="M12 24c3.2 0 5.9-1.1 7.9-2.9l-3.9-3c-1 .7-2.4 1.2-4 1.2-3 0-5.6-2-6.6-4.8H1.4v3.1A12 12 0 0 0 12 24Z" />
                  <path fill="#FBBC05" d="M5.4 14.5a7.2 7.2 0 0 1 0-4.6V6.8H1.4a12 12 0 0 0 0 10.8l4-3.1Z" />
                  <path fill="#EA4335" d="M12 4.8c1.7 0 3.3.6 4.5 1.8l3.4-3.4A12 12 0 0 0 1.4 6.8l4 3.1C6.4 6.8 9 4.8 12 4.8Z" />
                </svg>
                via Google
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
