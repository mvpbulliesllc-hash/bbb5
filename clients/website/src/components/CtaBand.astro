---
import { business } from '@/config/business';

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Ready to protect your biggest investment?',
  sub = 'Free estimates. Honest pricing. Craftsmanship that lasts.',
} = Astro.props;
---

<section class="section-dark relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-transparent via-gold-400 to-transparent" aria-hidden="true"></div>
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-4 py-20 text-center sm:px-6 lg:py-24">
    <h2 class="h-display max-w-2xl text-3xl text-white sm:text-4xl">{heading}</h2>
    <p class="max-w-xl text-lg text-white/75">{sub}</p>
    <div class="mt-2 flex flex-wrap justify-center gap-4">
      <a href="/contact/" class="btn-gold text-lg">Get a Free Estimate</a>
      <a href={business.phoneHref} class="btn-outline text-lg">Call {business.phone}</a>
    </div>
    <p class="text-sm text-white/50">{business.license} · Licensed &amp; insured · Financing available</p>
  </div>
</section>
