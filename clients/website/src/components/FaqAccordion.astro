---
interface Props {
  faqs: ReadonlyArray<{ q: string; a: string }>;
  heading?: string;
}
const { faqs, heading = 'Frequently asked questions' } = Astro.props;
---

{
  faqs.length > 0 && (
    <section class="mx-auto max-w-4xl px-4 py-14 sm:px-6">
      <h2 class="h-display text-3xl text-navy-950">{heading}</h2>
      <div class="mt-6 divide-y divide-sand-200 rounded-2xl bg-white ring-1 ring-sand-200">
        {faqs.map((f) => (
          <details class="group px-5 py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display font-bold text-navy-900">
              {f.q}
              <span class="text-gold-600 transition group-open:rotate-45" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </span>
            </summary>
            <p class="mt-3 leading-relaxed text-navy-900/80">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
