---
import { getCollection } from 'astro:content';

interface Props {
  heading?: string;
  limit?: number;
}
const { heading = 'What we do', limit = 10 } = Astro.props;
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order).slice(0, limit);
---

<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
  <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-600">Our services</p>
  <h2 class="h-display mt-3 text-3xl text-navy-950 sm:text-4xl">{heading}</h2>
  <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      services.map((s) => (
        <a
          href={`/${s.id}/`}
          class="group overflow-hidden rounded-2xl bg-white ring-1 ring-sand-200 transition hover:-translate-y-1 hover:shadow-lift"
        >
          <div class="aspect-[4/3] overflow-hidden bg-navy-100">
            <img
              src={s.data.image}
              alt={s.data.title}
              width="640"
              height="480"
              loading="lazy"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-5">
            <h3 class="h-display text-xl text-navy-950">{s.data.title}</h3>
            <p class="mt-1.5 text-sm text-navy-900/70">{s.data.heroTagline}</p>
            <p class="mt-3 font-display text-sm font-bold text-gold-600 group-hover:underline">Learn more →</p>
          </div>
        </a>
      ))
    }
  </div>
</section>
