---
import { getCollection } from 'astro:content';
import Img from '@/components/Img.astro';

interface Props {
  heading?: string;
  limit?: number;
}
const { heading = 'What we do', limit = 10 } = Astro.props;
const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order).slice(0, limit);
---

<section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:py-24">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="eyebrow text-gold-600">Our services</p>
      <h2 class="h-display mt-3 text-3xl text-navy-950 sm:text-4xl">{heading}</h2>
    </div>
    <a href="/services/" class="group hidden items-center gap-1.5 font-display text-sm font-bold text-navy-800 transition hover:text-gold-600 sm:inline-flex">
      All services
      <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
    </a>
  </div>
  <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
    {
      services.map((s) => (
        <a href={`/${s.id}/`} class="card-premium group overflow-hidden">
          <div class="relative aspect-[4/3] overflow-hidden bg-navy-100">
            <Img
              src={s.data.image}
              alt={s.data.title}
              widths={[400, 640, 800]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.06]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950/50 via-transparent to-transparent opacity-70 transition-opacity duration-300 group-hover:opacity-40" aria-hidden="true" />
          </div>
          <div class="flex items-start justify-between gap-3 p-6">
            <div>
              <h3 class="h-display text-xl text-navy-950">{s.data.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-navy-900/70">{s.data.heroTagline}</p>
            </div>
            <span
              class="mt-1 flex h-9 w-9 flex-none items-center justify-center rounded-full bg-sand-100 text-navy-900 transition-all duration-200 group-hover:bg-gold-400 group-hover:text-navy-950"
              aria-hidden="true"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5">
                <path d="M5 12h14m-6-7 7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
