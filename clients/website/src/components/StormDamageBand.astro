---
import { business } from '@/config/business';

/**
 * Storm damage / insurance-claim band — surfaces the fastest-revenue offer
 * directly below the hero, instead of leaving it buried in the homepage FAQ.
 *
 * Angle: hail/storm damage, we meet your adjuster, drone-document the full
 * claim, and tarp active leaks the same day. One scannable CTA to the
 * dedicated /storm-damage/ service page. Styling mirrors the sand/gold icon
 * band pattern (see TrustBar.astro) so it reads as part of the existing system.
 */
const points = [
  {
    label: 'We meet your adjuster on-site',
    sub: 'The scope covers everything your policy allows.',
    icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m19 8 2 2 4-4"/>',
  },
  {
    label: 'Drone-documented proof',
    sub: 'Every angle photographed — evidence, not a guess.',
    icon: '<path d="M12 8v8M8 12h8"/><circle cx="12" cy="12" r="3"/><path d="M4 4h3v3H4zM17 4h3v3h-3zM4 17h3v3H4zM17 17h3v3h-3z"/>',
  },
  {
    label: 'Emergency tarping available',
    sub: 'We stop active leaks the day we visit.',
    icon: '<path d="M12 2 3 7v6c0 5 3.8 8.3 9 9 5.2-.7 9-4 9-9V7l-9-5Z"/>',
  },
];
---

<section class="relative border-y border-sand-200 bg-sand-50" aria-labelledby="storm-heading">
  <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-transparent via-gold-400 to-transparent" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_1fr] lg:items-center">
      <div>
        <p class="eyebrow text-gold-600">Storm &amp; hail damage</p>
        <h2 id="storm-heading" class="h-display mt-3 text-3xl text-navy-950 sm:text-4xl">
          Storm damage? We meet your adjuster and document the whole claim.
        </h2>
        <p class="mt-4 max-w-xl text-navy-900/70">
          Wind, hail, or a nor'easter at the Shore — we drone-photograph every angle, build the evidence your insurer
          needs, and tarp active leaks the same day. One local crew from claim to finished roof.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a href="/storm-damage/" class="btn-gold text-lg" data-cta="storm-claim-check">Start My Claim Check</a>
          <a
            href={business.phoneHref}
            class="inline-flex items-center justify-center rounded-lg border-2 border-navy-950 px-6 py-3 font-display font-bold text-navy-950 transition hover:bg-navy-950 hover:text-white"
            data-cta="storm-call"
          >
            Call {business.phone}
          </a>
        </div>
      </div>

      <ul class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
        {
          points.map((p) => (
            <li class="card-premium flex items-start gap-3 p-4">
              <span class="mt-0.5 flex h-9 w-9 flex-none items-center justify-center rounded-full bg-gold-100 text-gold-700" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} />
              </span>
              <span>
                <p class="font-display text-sm font-extrabold text-navy-950">{p.label}</p>
                <p class="mt-0.5 text-xs leading-relaxed text-navy-900/60">{p.sub}</p>
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
