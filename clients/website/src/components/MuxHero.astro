---
import { business } from '@/config/business';
import Img from '@/components/Img.astro';

/**
 * Homepage hero — a static, high-impact background image (the reel now lives
 * in its own full-width band directly below, see MuxFeatureVideo.astro).
 * Uses hero-home.jpg — a bright daytime shot, deliberately distinct from the
 * sunset clip below — rendered as the LCP image (eager + fetchpriority=high,
 * responsive AVIF/WebP).
 */
---

<section class="relative isolate overflow-hidden bg-navy-950 text-white">
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <Img
      src="/media/hero-home.jpg"
      alt=""
      priority
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      class="kenburns h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/70 to-navy-950/30"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/40 via-transparent to-navy-950"></div>
    <div
      class="absolute -right-40 -top-40 h-[36rem] w-[36rem] rounded-full bg-gold-500/10 blur-3xl"
      aria-hidden="true"
    >
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 pb-24 pt-20 sm:px-6 sm:pt-28 lg:pb-32">
    <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 ring-1 ring-white/20 backdrop-blur-sm">
      <span class="flex gap-0.5 text-gold-400" aria-hidden="true">
        {
          Array.from({ length: 5 }).map(() => (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
            </svg>
          ))
        }
      </span>
      <span class="text-sm font-semibold text-white/90">Trusted by homeowners across the Jersey Shore</span>
    </div>
    <p class="eyebrow mt-6 text-gold-300">
      Roofing · Siding · Windows · Doors · Decks
    </p>
    <h1 class="h-display mt-4 max-w-3xl text-4xl leading-[1.05] sm:text-5xl lg:text-6xl">
      The Jersey Shore’s <span class="text-shimmer">New Standard</span> in Roofing &amp; Exteriors
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/85">
      {business.tagline} Family-run, {business.license} licensed &amp; insured, serving {business.areaServed} — with
      workmanship that speaks from every ridge line.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-4">
      <a href="/contact/" class="btn-gold text-lg" data-cta="hero-estimate">Get a Free Estimate</a>
      <a href={business.phoneHref} class="btn-outline text-lg" data-cta="hero-call">
        Call {business.phone}
      </a>
    </div>
    <dl class="glass-card mt-14 grid max-w-3xl grid-cols-3 divide-x divide-white/15">
      <div class="px-5 py-5 sm:px-7">
        <dd class="font-display text-2xl font-extrabold text-gold-300 [font-variant-numeric:tabular-nums] sm:text-3xl" data-countup="30">
          30 roofs
        </dd>
        <dt class="mt-1 text-xs uppercase tracking-wider text-white/60">In 30 days — our record</dt>
      </div>
      <div class="px-5 py-5 sm:px-7">
        <dd class="font-display text-2xl font-extrabold text-gold-300 [font-variant-numeric:tabular-nums] sm:text-3xl" data-countup="55">
          55+ yrs
        </dd>
        <dt class="mt-1 text-xs uppercase tracking-wider text-white/60">Combined experience</dt>
      </div>
      <div class="px-5 py-5 sm:px-7">
        <dd class="font-display text-2xl font-extrabold text-gold-300 sm:text-3xl">Free</dd>
        <dt class="mt-1 text-xs uppercase tracking-wider text-white/60">Itemized estimates</dt>
      </div>
    </dl>
  </div>
</section>
