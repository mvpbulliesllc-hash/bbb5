---
import { business } from '@/config/business';

/**
 * Homepage hero — a static, high-impact background image (the reel now lives
 * in its own full-width Mux band directly below, see MuxFeatureVideo.astro).
 * Uses hero-static.jpg (a purpose-built cinematic shot) with hero-poster.jpg
 * as a graceful fallback if the static asset isn't present yet.
 */
const heroHeadline = 'The Jersey Shore’s New Standard in Roofing & Exteriors';
---

<section class="relative isolate overflow-hidden bg-navy-950 text-white">
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <img
      src="/media/hero-static.jpg"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      onerror="this.onerror=null;this.src='/media/hero-poster.jpg';"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/80 via-navy-950/60 to-navy-950/90"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 pb-24 pt-20 sm:px-6 sm:pt-28 lg:pb-32">
    <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-300">
      Roofing · Siding · Windows · Doors · Decks
    </p>
    <h1 class="h-display mt-4 max-w-3xl text-4xl leading-[1.05] sm:text-5xl lg:text-6xl">
      {heroHeadline}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-white/85">
      {business.tagline} Family-run, {business.license} licensed &amp; insured, serving {business.areaServed} — with
      workmanship that speaks from every ridge line.
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-4">
      <a href="/contact/" class="btn-gold text-lg" data-cta="hero-estimate">Get a Free Estimate</a>
      <a href={business.phoneHref} class="btn-outline text-lg" data-cta="hero-call">
        Call {business.phone}
      </a>
    </div>
    <dl class="mt-12 grid max-w-2xl grid-cols-3 gap-6 border-t border-white/15 pt-8">
      <div>
        <dt class="text-xs uppercase tracking-wider text-white/60">Recent pace</dt>
        <dd class="font-display text-2xl font-extrabold text-gold-300">30 roofs / 30 days</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-white/60">Combined experience</dt>
        <dd class="font-display text-2xl font-extrabold text-gold-300">55+ years</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wider text-white/60">Estimates</dt>
        <dd class="font-display text-2xl font-extrabold text-gold-300">Always free</dd>
      </div>
    </dl>
  </div>
</section>
