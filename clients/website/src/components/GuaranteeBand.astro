---
/**
 * Named-guarantee risk-reversal band — lifts the workmanship warranty out of
 * process step 4 and gives it prominence right before the primary CTA.
 *
 * PLACEHOLDERS — owner must fill before merge (see PR description):
 *   GUARANTEE_NAME  — the named guarantee, e.g. "The Paragon Promise"
 *   GUARANTEE_TERMS — one line of terms, e.g. "workmanship guaranteed for 10 years, in writing, on every roof we install"
 * Rendered literally so the tokens are impossible to miss on the page.
 */
const GUARANTEE_NAME = '{{GUARANTEE_NAME}}';
const GUARANTEE_TERMS = '{{GUARANTEE_TERMS}}';
---

<section class="bg-sand-50 pb-4 pt-8 sm:pb-6" aria-labelledby="guarantee-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="flex flex-col items-start gap-4 rounded-2xl border border-gold-200 bg-white p-6 shadow-lift ring-1 ring-sand-200 sm:flex-row sm:items-center sm:gap-5 sm:p-7">
      <span class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-gold-100 text-gold-700" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 4 5v6c0 5 3.4 8.3 8 9 4.6-.7 8-4 8-9V5l-8-3Z" />
          <path d="m9 12 2 2 4-4" />
        </svg>
      </span>
      <div>
        <h2 id="guarantee-heading" class="h-display text-xl text-navy-950 sm:text-2xl">
          Backed by {GUARANTEE_NAME}
        </h2>
        <p class="mt-1.5 text-navy-900/70">{GUARANTEE_TERMS}</p>
      </div>
    </div>
  </div>
</section>
