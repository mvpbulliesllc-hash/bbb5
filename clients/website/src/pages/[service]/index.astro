---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import TrustBar from '@/components/TrustBar.astro';
import ProcessSteps from '@/components/ProcessSteps.astro';
import Testimonials from '@/components/Testimonials.astro';
import FinancingBand from '@/components/FinancingBand.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import LeadForm from '@/components/LeadForm.astro';
import TownGrid from '@/components/TownGrid.astro';
import CtaBand from '@/components/CtaBand.astro';
import BeforeAfterSlider from '@/components/BeforeAfterSlider.astro';
import QuickFacts from '@/components/QuickFacts.astro';
import { serviceSchema, faqSchema, breadcrumbSchema } from '@/lib/schema';
import { business } from '@/config/business';
import Img from '@/components/Img.astro';
import { ogImageUrl } from '@/lib/images';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({ params: { service: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services/' },
  { name: entry.data.title, url: `/${entry.id}/` },
];
// Citable GEO facts — complete declarative sentences an AI answer engine can
// quote verbatim. Keep in sync with page copy; bump the date on changes.
const quickFacts = [
  entry.data.priceRange
    ? `A typical ${entry.data.serviceName.toLowerCase()} at the Jersey Shore costs ${entry.data.priceRange} as of 2026, depending on size, materials, and scope.`
    : `${entry.data.serviceName} pricing is quoted with a free itemized estimate — no allowances, no surprises.`,
  `Paragon Exteriors LLC provides ${entry.data.serviceName.toLowerCase()} across Ocean County and Monmouth County, New Jersey.`,
  'Most residential roofing projects are torn off, installed, and cleaned up in a single day.',
  `Paragon Exteriors LLC is a licensed New Jersey home improvement contractor (${business.license}) and is fully insured.`,
  `Free estimates and financing are available — call ${business.phone}.`,
];

const leadServiceMap: Record<string, string> = {
  'roof-replacement': 'RoofReplacement',
  'roof-repair': 'RoofRepair',
  roofing: 'Roofing',
  siding: 'Siding',
  windows: 'Windows',
  doors: 'Doors',
  decks: 'Decks',
  gutters: 'Gutters',
  'commercial-roofing': 'Commercial',
  'storm-damage': 'RoofRepair',
};
---

<Base
  title={entry.data.metaTitle}
  description={entry.data.metaDescription}
  ogImage={await ogImageUrl(entry.data.image, Astro.site)}
  schemas={[
    serviceSchema({
      name: entry.data.serviceName,
      description: entry.data.metaDescription,
      url: `${business.url}/${entry.id}/`,
      priceRange: entry.data.priceRange,
    }),
    faqSchema(entry.data.faqs),
    breadcrumbSchema(crumbs),
  ]}
>
  <section class="relative isolate overflow-hidden bg-navy-950 text-white">
    <Img src={entry.data.image} alt="" priority widths={[768, 1280, 1920]} sizes="100vw" class="absolute inset-0 -z-10 h-full w-full object-cover opacity-25" />
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-24">
      <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-300">{business.areaServed}</p>
      <h1 class="h-display mt-4 max-w-3xl text-4xl sm:text-5xl">{entry.data.title}</h1>
      <p class="mt-5 max-w-2xl text-lg text-white/85">{entry.data.heroTagline}</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#estimate" class="btn-gold">Get a Free Estimate</a>
        <a href={business.phoneHref} class="btn-outline">Call {business.phone}</a>
      </div>
      {entry.data.priceRange && <p class="mt-6 text-sm text-white/70">Typical investment: <strong class="text-gold-300">{entry.data.priceRange}</strong> — financing available.</p>}
    </div>
  </section>
  <TrustBar />
  <Breadcrumbs items={crumbs} />

  <div class="mx-auto max-w-4xl px-4 pt-10 sm:px-6">
    <QuickFacts heading={`${entry.data.serviceName} — quick facts`} facts={quickFacts} lastUpdated="July 2026" />
  </div>

  <article class="prose-paragon mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Content />
  </article>

  <BeforeAfterSlider
    heading={`${entry.data.serviceName} — before and after`}
    subheading="Drag the handle to compare. Every project gets the same spec: full tear-off, proper flashing, and a magnetic-sweep cleanup."
    before="/media/projects/project-03.jpg"
    after="/media/projects/project-01.jpg"
    beforeAlt={`Home before ${entry.data.serviceName.toLowerCase()} by Paragon Exteriors`}
    afterAlt={`Completed ${entry.data.serviceName.toLowerCase()} by Paragon Exteriors in Ocean County NJ`}
  />

  <ProcessSteps />
  <Testimonials />
  <FinancingBand />
  {entry.data.comboEligible && <TownGrid service={entry.id} heading={`${entry.data.serviceName} across the Jersey Shore`} />}
  <FaqAccordion faqs={entry.data.faqs} heading={`${entry.data.serviceName} questions, answered`} />

  <section class="bg-navy-950 py-16" id="estimate">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <LeadForm service={leadServiceMap[entry.id] ?? 'Other'} heading={`Free ${entry.data.serviceName.toLowerCase()} estimate`} />
    </div>
  </section>
  <CtaBand />
</Base>
