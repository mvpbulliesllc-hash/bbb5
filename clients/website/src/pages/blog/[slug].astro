---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import CtaBand from '@/components/CtaBand.astro';
import LeadForm from '@/components/LeadForm.astro';
import { articleSchema, faqSchema, breadcrumbSchema } from '@/lib/schema';
import { business } from '@/config/business';
import Img from '@/components/Img.astro';
import { ogImageUrl } from '@/lib/images';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const url = `/blog/${entry.id}/`;
const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guides', url: '/blog/' },
  { name: entry.data.title, url },
];
const related = (await getCollection('posts', (p) => p.id !== entry.id && p.data.category === entry.data.category)).slice(0, 3);
const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const og = await ogImageUrl(entry.data.image, Astro.site);
---

<Base
  title={entry.data.metaTitle}
  description={entry.data.metaDescription}
  ogImage={og}
  ogType="article"
  schemas={[
    articleSchema({
      title: entry.data.title,
      description: entry.data.description,
      url: `${business.url}${url}`,
      image: og,
      pubDate: entry.data.pubDate,
      updatedDate: entry.data.updatedDate,
    }),
    faqSchema(entry.data.faqs),
    breadcrumbSchema(crumbs),
  ]}
>
  <Breadcrumbs items={crumbs} />
  <article class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-600">{entry.data.category}</p>
    <h1 class="h-display mt-3 text-4xl leading-tight text-navy-950 sm:text-5xl">{entry.data.title}</h1>
    <p class="mt-4 text-sm text-navy-900/60">
      By {business.name} · Updated {fmt.format(entry.data.updatedDate ?? entry.data.pubDate)}
    </p>
    <Img
      src={entry.data.image}
      alt=""
      priority
      widths={[400, 800, 1280]}
      sizes="(max-width: 896px) 100vw, 896px"
      class="mt-8 aspect-video w-full rounded-2xl object-cover"
    />
    <div class="prose-paragon mt-10">
      <Content />
    </div>
  </article>

  <FaqAccordion faqs={entry.data.faqs} />

  <section class="bg-navy-950 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <LeadForm heading="Talk to a real local expert" />
    </div>
  </section>

  {
    related.length > 0 && (
      <nav class="mx-auto max-w-7xl px-4 py-12 sm:px-6" aria-label="Related guides">
        <h2 class="h-display text-2xl text-navy-950">Keep reading</h2>
        <ul class="mt-5 grid gap-6 md:grid-cols-3">
          {related.map((p) => (
            <li>
              <a href={`/blog/${p.id}/`} class="group block overflow-hidden rounded-2xl ring-1 ring-sand-200 transition hover:shadow-lift">
                <Img src={p.data.image} alt="" widths={[300, 480, 640]} sizes="(max-width: 768px) 100vw, 33vw" class="aspect-video w-full object-cover" />
                <div class="p-5">
                  <p class="font-display font-bold text-navy-950 group-hover:underline">{p.data.title}</p>
                  <p class="mt-1.5 text-sm text-navy-900/70">{p.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
  <CtaBand />
</Base>
