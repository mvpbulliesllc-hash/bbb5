---
import Base from '@/layouts/Base.astro';
import TrustBar from '@/components/TrustBar.astro';
import Testimonials from '@/components/Testimonials.astro';
import CtaBand from '@/components/CtaBand.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Img from '@/components/Img.astro';
import { business } from '@/config/business';
import { breadcrumbSchema } from '@/lib/schema';
import { resolveMedia } from '@/lib/images';

// Jarad's headshot ships separately; until it lands in src/assets/media the
// card renders a designed monogram instead of a broken image.
const jaradPhoto = resolveMedia('/media/team-jarad.jpg');

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about/' },
];
---

<Base
  title="About Paragon Exteriors LLC | Family-Run NJ Roofing Contractor"
  description="Meet Joe Ballaccomo & Franchi Vacchiano, equal partners with 55+ combined years of roofing and construction experience, and CTO Jarad Derochey — the technology behind the Jersey Shore's most trusted family-run exterior contractor."
  schemas={[breadcrumbSchema(crumbs)]}
>
  <section class="bg-navy-950 py-16 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-300">Our story</p>
      <h1 class="h-display mt-4 max-w-3xl text-4xl sm:text-5xl">Family-run. Craft-obsessed. Jersey through and through.</h1>
      <p class="mt-5 max-w-2xl text-lg text-white/85">{business.tagline}</p>
    </div>
  </section>
  <TrustBar />
  <Breadcrumbs items={crumbs} />

  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <div class="prose-paragon">
      <p>
        Paragon Exteriors is a trusted contractor specializing in residential and commercial exterior solutions —
        roofing, siding, windows, doors, and decks. With a focus on quality workmanship, attention to detail, and
        durable materials, our experienced team delivers exceptional results on every project, every time.
      </p>
      <p>
        We're not a franchise and we're not a sales operation with subcontracted crews. We're a family business built
        on two lifetimes in construction, and our name goes on every roof we install. That's why our commitment to
        excellence drives us to go above and beyond — from roof installations to brand-new decks — ensuring each job is
        completed with the highest standards of craftsmanship and professionalism.
      </p>
    </div>
  </section>

  <section class="bg-sand-50 py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-600">The family behind Paragon</p>
      <h2 class="h-display mt-2 text-3xl text-navy-950 sm:text-4xl">Meet Joe &amp; Franchi</h2>

      <!-- Joe & Franchi — equal partners, matching cards -->
      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <div class="flex flex-col overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-sand-200">
          <div class="relative min-h-[340px] bg-navy-950">
            <Img
              src="/media/team-joe.jpg"
              alt="Giuseppe (Joe) Ballaccomo, Managing Partner of Paragon Exteriors"
              widths={[440, 700, 900]}
              sizes="(max-width: 1024px) 100vw, 50vw"
              class="h-full w-full object-cover object-top"
            />
          </div>
          <div class="flex flex-1 flex-col p-7 sm:p-8">
            <h3 class="h-display text-3xl text-navy-950">Giuseppe “Joe” Ballaccomo</h3>
            <p class="mt-1 font-display text-sm font-bold uppercase tracking-wider text-gold-600">Managing Partner</p>
            <p class="mt-4 leading-relaxed text-navy-900/85">{business.founders[0].bio}</p>
            <div class="mt-auto pt-6">
              <a href={business.phoneHref} class="btn-gold" data-cta="about-call-joe">Call Joe · {business.phone}</a>
            </div>
          </div>
        </div>

        <div class="flex flex-col overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-sand-200">
          <div class="relative min-h-[340px] bg-navy-950">
            <Img
              src="/media/team-franchi.jpg"
              alt="Franchi Vacchiano, Managing Partner of Paragon Exteriors"
              widths={[440, 700, 900]}
              sizes="(max-width: 1024px) 100vw, 50vw"
              class="h-full w-full object-cover object-top"
            />
          </div>
          <div class="flex flex-1 flex-col p-7 sm:p-8">
            <h3 class="h-display text-3xl text-navy-950">Franchi Vacchiano</h3>
            <p class="mt-1 font-display text-sm font-bold uppercase tracking-wider text-gold-600">Managing Partner · Master Builder</p>
            <p class="mt-4 leading-relaxed text-navy-900/85">{business.founders[1].bio}</p>
            <div class="mt-auto pt-6">
              <a href="/contact/" class="btn-navy">Get a free estimate</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Jarad — CTO, the technology behind the craft -->
      <div class="mt-10">
        <p class="font-display text-sm font-bold uppercase tracking-[0.25em] text-gold-600">The technology behind the craft</p>
        <div class="mt-4 grid overflow-hidden rounded-3xl bg-white shadow-lift ring-1 ring-sand-200 lg:grid-cols-[minmax(0,38%)_1fr]">
          <div class="section-dark relative min-h-[340px]">
            {
              jaradPhoto ? (
                <Img
                  src="/media/team-jarad.jpg"
                  alt="Jarad Derochey, Chief Technology Officer of Paragon Exteriors"
                  widths={[440, 700, 900]}
                  sizes="(max-width: 1024px) 100vw, 38vw"
                  class="absolute inset-0 h-full w-full object-cover object-top"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                  <span class="glass-card flex h-32 w-32 items-center justify-center font-display text-5xl font-extrabold text-gold-300">
                    JD
                  </span>
                </div>
              )
            }
            <span class="absolute left-5 top-5 rounded-full bg-gold-500 px-3.5 py-1.5 font-display text-xs font-bold uppercase tracking-wide text-navy-950 shadow-lift">
              See it before we build it
            </span>
          </div>
          <div class="flex flex-col justify-center p-8 sm:p-10">
            <h3 class="h-display text-3xl text-navy-950">{business.cto.name}</h3>
            <p class="mt-1 font-display text-sm font-bold uppercase tracking-wider text-gold-600">{business.cto.role}</p>
            <p class="mt-5 leading-relaxed text-navy-900/85">{business.cto.bio}</p>
            <p class="mt-4 leading-relaxed text-navy-900/70">
              Most contractors hand you a brochure and a color swatch. Jarad renders your actual house with the actual
              materials — change the shingle color, swap the siding profile, compare options side by side — and the crew
              builds exactly what you approved. No surprises, no buyer's remorse.
            </p>
          </div>
        </div>
      </div>
      <div class="mt-10 grid gap-6 rounded-2xl bg-navy-950 p-8 text-white md:grid-cols-3">
        <div>
          <p class="font-display text-3xl font-extrabold text-gold-300">55+ years</p>
          <p class="mt-1 text-sm text-white/70">combined construction experience</p>
        </div>
        <div>
          <p class="font-display text-3xl font-extrabold text-gold-300">30 roofs / 30 days</p>
          <p class="mt-1 text-sm text-white/70">our record pace, quality intact</p>
        </div>
        <div>
          <p class="font-display text-3xl font-extrabold text-gold-300">{business.license}</p>
          <p class="mt-1 text-sm text-white/70">licensed & fully insured</p>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />
  <CtaBand heading="Work with a crew that treats your home like family" />
</Base>
