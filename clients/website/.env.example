# Paragon Exteriors website — runtime integration switches.
# All optional: every feature degrades gracefully when unset.
# NEVER commit real secrets; these are all public (client-side) identifiers.

# Mux playback ID for the homepage hero (upload public/media/hero-reel.mp4 at dashboard.mux.com,
# copy the playback ID here). Until set, the hero falls back to the local video file.
PUBLIC_MUX_PLAYBACK_ID=

# CRM lead capture endpoint (FSH.Starter API): https://<api-host>/api/v1/crm/leads
# Until set, the form falls back to a pre-filled email.
PUBLIC_LEADS_API=
# Finbuckle tenant identifier sent as the `tenant` header (default: root)
PUBLIC_TENANT=root

# Analytics
PUBLIC_GA4_ID=
PUBLIC_PLAUSIBLE_DOMAIN=

# Voice agent (web widget) — ElevenLabs Conversational AI agent id.
# Phone answering via Hume EVI + Twilio needs no site config: see docs/voice-agent.md
PUBLIC_ELEVENLABS_AGENT_ID=

# Online estimate booking (optional)
PUBLIC_CALENDLY_URL=
