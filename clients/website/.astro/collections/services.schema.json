{
  "$ref": "#/definitions/services",
  "definitions": {
    "services": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "metaTitle": {
          "type": "string"
        },
        "metaDescription": {
          "type": "string",
          "maxLength": 175
        },
        "heroTagline": {
          "type": "string"
        },
        "serviceName": {
          "type": "string"
        },
        "image": {
          "type": "string",
          "default": "/media/placeholder.jpg"
        },
        "order": {
          "type": "number",
          "default": 50
        },
        "priceRange": {
          "type": "string"
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "q",
              "a"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "comboEligible": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "metaTitle",
        "metaDescription",
        "heroTagline",
        "serviceName"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}